[
  {
    "name": "View Habits — empty state",
    "steps": [
      {
        "send": { "callback": "habits:view" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "No habits yet — tap ➕ Create Habit to start tracking." } }
        ]
      }
    ]
  },
  {
    "name": "View Habits — shows habits after creation",
    "steps": [
      {
        "send": { "callback": "habit:create" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What habit do you want to track?" } }
        ]
      },
      {
        "send": { "text": "Drink water" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Got it — \"Drink water\". How often?" } }
        ]
      },
      {
        "send": { "callback": "habit:sched:daily" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What time should I remind you?" } }
        ]
      },
      {
        "send": { "callback": "habit:time:08:00" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Confirm your new habit:\n\n📝 Drink water\n🔁 Every day\n⏰ 08:00" } }
        ]
      },
      {
        "send": { "callback": "habit:create:confirm" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "✅ Habit created!\n\nYou're tracking \"Drink water\" with a reminder at 08:00. Keep it up!" } }
        ]
      },
      {
        "send": { "callback": "habits:view" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "Your habits:\n\nDrink water — 0 day streak" } }
        ]
      }
    ]
  }
]
