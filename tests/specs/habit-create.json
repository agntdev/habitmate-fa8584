[
  {
    "name": "Create Habit — title prompt",
    "steps": [
      {
        "send": { "callback": "habit:create" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What habit do you want to track?" } }
        ]
      }
    ]
  },
  {
    "name": "Create Habit — full flow",
    "steps": [
      {
        "send": { "callback": "habit:create" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What habit do you want to track?" } }
        ]
      },
      {
        "send": { "text": "Read 10 pages" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Got it — \"Read 10 pages\". How often?" } }
        ]
      },
      {
        "send": { "callback": "habit:sched:daily" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What time should I remind you?" } }
        ]
      },
      {
        "send": { "callback": "habit:time:08:00" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Confirm your new habit:\n\n📝 Read 10 pages\n🔁 Every day\n⏰ 08:00" } }
        ]
      },
      {
        "send": { "callback": "habit:create:confirm" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "✅ Habit created!\n\nYou're tracking \"Read 10 pages\" with a reminder at 08:00. Keep it up!" } }
        ]
      }
    ]
  }
]
